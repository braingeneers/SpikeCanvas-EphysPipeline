# Maxwell Ephys Pipeline Configuration Template
# Copy this file to .env and fill in your institution-specific values
# The .env file is gitignored to keep credentials secure

# ============================================================================
# S3 Storage Configuration (REQUIRED)
# ============================================================================
# Your S3-compatible bucket name (without s3:// prefix)
S3_BUCKET=your-institution-bucket

# Root prefix within bucket for ephys data
S3_PREFIX=ephys

# Optional: Override input/output prefixes if different from root
# S3_INPUT_PREFIX=ephys/raw
# S3_OUTPUT_PREFIX=ephys/processed

# ============================================================================
# AWS Credentials (Choose ONE method)
# ============================================================================
# Method 1: Direct credentials (for testing/development only)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Method 2: IAM Role (RECOMMENDED for production)
# AWS_ROLE_ARN=arn:aws:iam::123456789:role/ephys-processing-role
# AWS_SESSION_NAME=ephys-pipeline

# Method 3: AWS Profile (if using ~/.aws/credentials)
# AWS_PROFILE=your-profile-name

# AWS Region
AWS_REGION=us-west-2

# ============================================================================
# S3 Endpoint Configuration
# ============================================================================
# For AWS S3: use default endpoints (leave commented)
# For custom S3-compatible storage (MinIO, Ceph, etc): uncomment and set
ENDPOINT_URL=https://s3.braingeneers.gi.ucsc.edu
S3_ENDPOINT=s3.braingeneers.gi.ucsc.edu

# ============================================================================
# Service Storage Paths
# ============================================================================
# Where pipeline services store job state, parameters, logs
# Built from S3_BUCKET if not explicitly set
SERVICE_ROOT=s3://your-institution-bucket/services/mqtt_job_listener

# Override individual service paths (optional)
# SERVICE_BUCKET=${SERVICE_ROOT}/csvs
# PARAMETER_BUCKET=${SERVICE_ROOT}/params

# Additional data type buckets (optional, for multi-domain deployments)
# FLUIDICS_BUCKET=s3://your-institution-bucket/fluidics/
# INTEGRATED_BUCKET=s3://your-institution-bucket/integrated/

# ============================================================================
# Kubernetes Configuration
# ============================================================================
# Namespace for job execution
NRP_NAMESPACE=braingeneers

# Container images (override to use custom builds)
# KILOSORT_IMAGE=surygeng/kilosort_docker:v0.2
# CURATION_IMAGE=surygeng/qm_curation:v0.2
# CONNECTIVITY_IMAGE=surygeng/connectivity:v0.1
# VISUALIZATION_IMAGE=surygeng/visualization:v0.1
# LFP_IMAGE=surygeng/local_field_potential:v0.1

# Job resource limits (optional overrides)
# JOB_CPU_REQUEST=12
# JOB_MEM_REQUEST=32
# JOB_EPHEMERAL_REQUEST=400
# JOB_GPU_LIMIT=1

# ============================================================================
# Dashboard Configuration
# ============================================================================
# Port for web dashboard
DASHBOARD_PORT=8050

# ============================================================================
# Notes
# ============================================================================
# 1. Keep .env file secure - it contains credentials
# 2. For production, use IAM roles instead of access keys
# 3. All S3 paths are built from S3_BUCKET + S3_PREFIX automatically
# 4. Services will fail if S3_BUCKET is not set
