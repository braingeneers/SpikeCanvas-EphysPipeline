# SpikeCanvas Configuration Template
# ====================================
# Copy this file to .env and fill in your institution-specific values
# The .env file is gitignored to keep credentials secure
#
# Quick Start Guide:
# 1. Copy this file: cp .env.template .env
# 2. Fill in S3_BUCKET (REQUIRED)
# 3. Configure ONE AWS credentials method
# 4. Set your Kubernetes namespace
# 5. Run: docker-compose up -d

# ============================================================================
# S3 Storage Configuration (REQUIRED)
# ============================================================================
# Your S3-compatible bucket name (without s3:// prefix)
# Examples:
#   - AWS S3: my-lab-data
#   - MinIO: minio-bucket
#   - Ceph: braingeneers
S3_BUCKET=your-institution-bucket

# Root prefix within bucket for ephys data
# This organizes your data: s3://bucket/ephys/...
S3_PREFIX=ephys

# Optional: Override input/output prefixes if different from root
# S3_INPUT_PREFIX=ephys/raw
# S3_OUTPUT_PREFIX=ephys/processed

# ============================================================================
# AWS Credentials (Choose ONE method)
# ============================================================================
# Method 1: Direct credentials (for testing/development only)
# ⚠️ WARNING: Not recommended for production - use AWS profiles or IAM roles
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Method 2: AWS Profile (RECOMMENDED - if using ~/.aws/credentials)
# This mounts your ~/.aws directory into containers
# AWS_PROFILE=default

# AWS Region (required for AWS S3, optional for other S3-compatible storage)
AWS_REGION=us-west-2

# ============================================================================
# S3 Endpoint Configuration
# ============================================================================
# For AWS S3: Leave these COMMENTED OUT to use default AWS endpoints
# For custom S3-compatible storage (MinIO, Ceph, etc): UNCOMMENT and configure

# Example: Braingeneers PRP Ceph cluster
ENDPOINT_URL=https://s3.braingeneers.gi.ucsc.edu
S3_ENDPOINT=s3.braingeneers.gi.ucsc.edu

# Example: Local MinIO
# ENDPOINT_URL=http://minio.local:9000
# S3_ENDPOINT=minio.local:9000

# Example: Custom Ceph cluster
# ENDPOINT_URL=https://ceph.mylab.edu
# S3_ENDPOINT=ceph.mylab.edu

# ============================================================================
# Service Storage Paths
# ============================================================================
# Where pipeline services store job state, parameters, logs
# Default: s3://${S3_BUCKET}/services/mqtt_job_listener
# Override if you want a different location:
SERVICE_ROOT=s3://your-institution-bucket/services/mqtt_job_listener

# Additional service buckets (optional - for multi-bucket setups)
# SERVICE_BUCKET=${S3_BUCKET}
# PARAMETER_BUCKET=${S3_BUCKET}
# FLUIDICS_BUCKET=${S3_BUCKET}
# INTEGRATED_BUCKET=${S3_BUCKET}

# ============================================================================
# Kubernetes Configuration
# ============================================================================
# Namespace for job execution
# - Use "default" for single-tenant clusters
# - Use lab-specific namespace for multi-tenant clusters
NRP_NAMESPACE=default

# Job resource defaults (optional overrides)
# Adjust based on your cluster capacity and workload requirements
# JOB_CPU_REQUEST=12          # CPU cores
# JOB_MEM_REQUEST=32          # Memory in GB
# JOB_EPHEMERAL_REQUEST=400   # Ephemeral storage in GB
# JOB_GPU_LIMIT=1             # GPUs (for Kilosort)

# ============================================================================
# Container Images
# ============================================================================
# Override to use custom builds or different versions
# Default images are from Docker Hub: surygeng/*

# Spike sorting algorithm
KILOSORT_IMAGE=surygeng/kilosort_docker:v0.2

# Quality control and curation
CURATION_IMAGE=surygeng/qm_curation:v0.2

# Connectivity analysis
CONNECTIVITY_IMAGE=surygeng/connectivity:v0.1

# Data visualization
VISUALIZATION_IMAGE=surygeng/visualization:v0.1

# Local field potential analysis
LFP_IMAGE=surygeng/local_field_potential:v0.1

# MaxTwo data splitter (preprocessing)
MAXTWO_SPLITTER_IMAGE=surygeng/maxtwo_splitter:v0.1

# Service images
DASHBOARD_IMAGE=surygeng/maxwell_dashboard:v0.1
LISTENER_IMAGE=surygeng/spike_sorting_listener:v0.1
SCANNER_IMAGE=surygeng/job_scanner:v0.1

# ============================================================================
# Service Ports
# ============================================================================
# Dashboard web interface
DASHBOARD_PORT=8050

# MQTT broker
MQTT_PORT=1883              # MQTT protocol
MQTT_WS_PORT=9001           # MQTT over WebSocket

# Redis cache
REDIS_PORT=6379

# ============================================================================
# MQTT Configuration
# ============================================================================
# MQTT broker connection (internal docker network)
# These are set automatically by docker-compose, override if using external MQTT
# MQTT_BROKER=mqtt.local
# MQTT_PORT=1883

# MQTT authentication (optional - for production)
# If enabled, create password file: see mosquitto/config/README.md
# MQTT_USERNAME=dashboard
# MQTT_PASSWORD=secure-password

# ============================================================================
# Redis Configuration
# ============================================================================
# Redis connection (internal docker network)
# These are set automatically by docker-compose, override if using external Redis
# REDIS_HOST=redis.local
# REDIS_PORT=6379

# Redis authentication (optional - for production)
# REDIS_PASSWORD=secure-password

# ============================================================================
# Job Scanner Configuration
# ============================================================================
# How often to scan Kubernetes for job status updates (seconds)
SCAN_INTERVAL=60

# ============================================================================
# Advanced Configuration
# ============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Enable debug mode (verbose logging)
# DEBUG=false

# Custom parameter files location
# CUSTOM_PARAMS_DIR=./custom_params

